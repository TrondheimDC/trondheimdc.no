<tdc-section>
<section class="section" id="program" data-animate aria-labelledby="program-title">
  <div class="container stack">
    <header class="section__header">
      <h2 class="section__title text-h1" id="program-title">{{ t.program.title }}</h2>
    </header>

    {% if site.sessionizeEventId %}
      {# Sessionize schedule grid embed #}
      <div class="sessionize" id="sz-program"></div>
      <script type="text/javascript" src="https://sessionize.com/api/v2/{{ site.sessionizeEventId }}/view/GridSmart"></script>
    {% else %}
      <p class="section__lead text-lead">{{ t.program.placeholder }}</p>
    {% endif %}
  </div>
</section>
</tdc-section>
