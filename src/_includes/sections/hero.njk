{% from "components/button.njk" import button %}

<section class="section section--hero" id="hero" aria-label="TDC 2026">
  <div class="container hero__inner">
    {# Decorative hero mascot. Placeholder = duck.svg; swap for the Figma
       pixel-art duck (node 2:3) once that asset is exported. #}
    <img src="{{ '/assets/images/logos/duck.svg' | url }}" alt="" aria-hidden="true" class="hero__duck" width="240" height="240">

    <p class="hero__date text-display">{{ t.hero.date_full }}</p>
    <p class="hero__venue text-lead">{{ t.hero.venue }}</p>

    <div class="hero__actions cluster" style="--cluster-justify: center;">
      {{ button(t.hero.cta_tickets, site.ticketUrl, "primary", "lg", null, true) }}
    </div>
  </div>
</section>
