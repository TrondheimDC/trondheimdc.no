{% from "components/button.njk" import button %}

<tdc-section>
<section class="section section--surface" id="tickets" data-animate aria-labelledby="tickets-title">
  <div class="container stack">
    <header class="section__header stack stack-sm">
      <h2 class="section__title text-h1" id="tickets-title">{{ t.tickets.title }}</h2>
      <p class="section__lead text-lead">{{ t.tickets.description }}</p>
    </header>

    <div class="switcher" style="--switcher-threshold: 28rem;">
      <article class="card stack">
        <h3 class="card__title text-h3">{{ t.tickets.attendee_title }}</h3>
        <p class="card__body">{{ t.tickets.attendee_desc }}</p>
        {{ button(t.tickets.cta, site.ticketUrl, "primary", "md", null, true) }}
      </article>
      <article class="card stack">
        <h3 class="card__title text-h3">{{ t.tickets.partner_title }}</h3>
        <p class="card__body">{{ t.tickets.partner_desc }}</p>
        {% if t.tickets.partner_sold_out %}
          <span class="btn btn--ghost btn--disabled" aria-disabled="true">{{ t.tickets.partner_cta }}</span>
        {% else %}
          {{ button(t.tickets.partner_cta, site.partnerOrderUrl, "ghost") }}
        {% endif %}
      </article>
    </div>
  </div>
</section>
</tdc-section>
