{% set aboutContent = "./_includes/content/" + lang + "/about.md" %}

<tdc-section>
<section class="section section--about" id="about" data-animate aria-labelledby="about-title">
  <div class="container stack">
    <header class="section__header">
      <h2 class="section__title text-h1" id="about-title">{{ t.about.title }}</h2>
    </header>

    <div class="prose measure">
      {% renderFile aboutContent %}
    </div>
  </div>
</section>
</tdc-section>
