{% from "components/button.njk" import button %}

<tdc-section>
<section class="section" id="cfp" data-animate aria-labelledby="cfp-title">
  <div class="container stack">
    <header class="section__header">
      <h2 class="section__title text-h1" id="cfp-title">{{ t.cfp.title }}</h2>
    </header>
    <p class="section__lead text-lead">{{ t.cfp.body }}</p>
    {% if t.cfp.cta and site.cfpUrl %}
      <div class="cluster">
        {{ button(t.cfp.cta, site.cfpUrl, "primary", "lg", null, true) }}
      </div>
    {% endif %}
  </div>
</section>
</tdc-section>
