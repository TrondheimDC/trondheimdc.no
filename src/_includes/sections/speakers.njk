<tdc-section>
<section class="section section--surface" id="speakers" data-animate aria-labelledby="speakers-title">
  <div class="container stack">
    <header class="section__header">
      <h2 class="section__title text-h1" id="speakers-title">{{ t.speakers.title }}</h2>
    </header>

    {% if site.sessionizeEventId %}
      {# Sessionize speaker wall embed #}
      <div class="sessionize" id="sz-speakers"></div>
      <script type="text/javascript" src="https://sessionize.com/api/v2/{{ site.sessionizeEventId }}/view/SpeakerWall"></script>
    {% else %}
      <p class="section__lead text-lead">{{ t.speakers.placeholder }}</p>
    {% endif %}
  </div>
</section>
</tdc-section>
