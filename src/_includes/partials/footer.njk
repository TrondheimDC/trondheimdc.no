{% set t = i18n[lang] %}

<footer class="site-footer" id="contact">
  <div class="site-footer__inner container">
    <div class="site-footer__brand stack stack-sm">
      <span class="tdc-wordmark site-footer__wordmark" role="img" aria-label="{{ t.ui.logo_alt }}">
        <span class="tdc-wordmark__letter tdc-wordmark__letter--t" aria-hidden="true"></span>
        <span class="tdc-wordmark__letter tdc-wordmark__letter--d" aria-hidden="true"></span>
        <span class="tdc-wordmark__letter tdc-wordmark__letter--c" aria-hidden="true"></span>
      </span>
      <p class="site-footer__info text-label">{{ t.footer.copyright }}</p>
      <p class="site-footer__info">{{ t.hero.date_full }} · {{ t.hero.venue }}</p>
    </div>

    <div class="site-footer__contact stack stack-sm">
      <p class="site-footer__info"><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
      <p class="site-footer__info"><a href="mailto:{{ site.partnerEmail }}">{{ site.partnerEmail }}</a></p>
    </div>

    <div class="site-footer__social stack stack-sm">
      <p class="site-footer__social-title text-label">{{ t.footer.find_us }}</p>
      <ul class="site-footer__social-links cluster" role="list">
        <li><a href="{{ site.social.linkedin }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5A2.5 2.5 0 1 0 5 8.5a2.5 2.5 0 0 0-.02-5zM3 9h4v12H3zM10 9h3.8v1.7h.05c.53-1 1.83-2.05 3.76-2.05 4.02 0 4.76 2.65 4.76 6.1V21h-4v-5.3c0-1.27-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V21h-4z"/></svg>
        </a></li>
        <li><a href="{{ site.social.facebook }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.55-1.5h1.65V3.6c-.29-.04-1.28-.12-2.43-.12-2.4 0-4.04 1.47-4.04 4.16v2.32H7.5V13h2.73v8z"/></svg>
        </a></li>
        <li><a href="{{ site.social.youtube }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M23 7.5a3 3 0 0 0-2.1-2.12C19.05 4.9 12 4.9 12 4.9s-7.05 0-8.9.48A3 3 0 0 0 1 7.5C.5 9.36.5 12 .5 12s0 2.64.5 4.5a3 3 0 0 0 2.1 2.12c1.85.48 8.9.48 8.9.48s7.05 0 8.9-.48A3 3 0 0 0 23 16.5c.5-1.86.5-4.5.5-4.5s0-2.64-.5-4.5zM9.75 15.5v-7l6 3.5z"/></svg>
        </a></li>
        <li><a href="{{ site.social.flickr }}" class="site-footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Flickr">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><circle cx="7" cy="12" r="4"/><circle cx="17" cy="12" r="4"/></svg>
        </a></li>
        <li><a href="mailto:{{ site.email }}" class="site-footer__social-link" aria-label="Email">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
        </a></li>
      </ul>
    </div>
  </div>

  <div class="site-footer__bottom container">
    <p>© {{ site.stats.year }} Trondheim Developer Conference. {% if lang == "en" %}All rights reserved.{% else %}Alle rettigheter reservert.{% endif %}</p>
    <a href="#main" class="site-footer__to-top">{{ t.ui.to_top }} ↑</a>
  </div>
</footer>
