{% set t = i18n[lang] %}
{% set home = '/en/' if lang == 'en' else '/' %}

<tdc-nav>
  <nav class="site-nav" aria-label="{{ 'Main navigation' if lang == 'en' else 'Hovednavigasjon' }}">
    <div class="site-nav__inner container container--wide">
      <a href="{{ home | url }}" class="site-nav__brand" aria-label="TDC 2026 — {{ t.ui.home }}">
        <span class="tdc-wordmark" aria-hidden="true">
          <span class="tdc-wordmark__letter tdc-wordmark__letter--t"></span>
          <span class="tdc-wordmark__letter tdc-wordmark__letter--d"></span>
          <span class="tdc-wordmark__letter tdc-wordmark__letter--c"></span>
        </span>
      </a>

      <button class="site-nav__toggle" type="button" aria-expanded="false" aria-controls="nav-menu" aria-label="{{ t.ui.menu }}">
        <span class="site-nav__toggle-bar" aria-hidden="true"></span>
        <span class="site-nav__toggle-bar" aria-hidden="true"></span>
        <span class="site-nav__toggle-bar" aria-hidden="true"></span>
      </button>

      <div class="site-nav__menu" id="nav-menu">
        <ul class="site-nav__links" role="list">
          <li><a href="#about" class="site-nav__link" data-section="about">{{ t.nav.about }}</a></li>
          <li><a href="#tickets" class="site-nav__link" data-section="tickets">{{ t.nav.tickets }}</a></li>
          <li><a href="#speakers" class="site-nav__link" data-section="speakers">{{ t.nav.speakers }}</a></li>
          <li><a href="#partner" class="site-nav__link" data-section="partner">{{ t.nav.partners }}</a></li>
          <li><a href="#faq" class="site-nav__link" data-section="faq">{{ t.nav.faq }}</a></li>
          <li><a href="#coc" class="site-nav__link" data-section="coc">{{ t.nav.coc }}</a></li>
        </ul>

        <div class="site-nav__actions">
          <div class="site-nav__lang" role="group" aria-label="{{ 'Language' if lang == 'en' else 'Språk' }}">
            <a href="{{ '/' | url }}" hreflang="no" lang="no" {% if lang == "no" %}aria-current="true"{% endif %}>NO</a>
            <span class="site-nav__lang-sep" aria-hidden="true">/</span>
            <a href="{{ '/en/' | url }}" hreflang="en" lang="en" {% if lang == "en" %}aria-current="true"{% endif %}>EN</a>
          </div>

          <tdc-theme-toggle
            data-label-light="{{ t.ui.theme_light }}"
            data-label-dark="{{ t.ui.theme_dark }}"></tdc-theme-toggle>
        </div>
      </div>
    </div>
  </nav>
</tdc-nav>
